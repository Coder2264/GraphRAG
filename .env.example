# ------------------------------------------------------------------
# API Keys — fill in the ones you need
# ------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

# ------------------------------------------------------------------
# PostgreSQL (pgvector) — RAG vector store
# ------------------------------------------------------------------
POSTGRES_DSN=postgresql+asyncpg://user:password@localhost:5432/graphrag

# ------------------------------------------------------------------
# Neo4j — GraphRAG graph store
# ------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
