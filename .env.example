# ------------------------------------------------------------------
# API Keys — fill in the ones you need
# ------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

# ------------------------------------------------------------------
# Gemini
# ------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_LLM_MODEL=gemini-3-flash-preview
GEMINI_EMBED_MODEL=models/gemini-embedding-exp-03-07
GEMINI_EXTRACTION_MODEL=gemini-3-flash-preview

# Embedding vector dimension — MUST match the Gemini embedding model output:
#   gemini-embedding-exp-03-07 → 3072
EMBEDDING_DIM=3072

# Chunking (RAG vector store)
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Graph extraction chunking (larger than RAG chunks; entity extraction needs more context)
GRAPH_EXTRACTION_CHUNK_SIZE=6000
GRAPH_EXTRACTION_CHUNK_OVERLAP=800

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ------------------------------------------------------------------
# Provider selection — swap instantly without code changes
# ------------------------------------------------------------------
DEFAULT_LLM=gemini                  # options: gemini | ollama | in_memory
DEFAULT_EMBEDDER=gemini             # options: gemini | ollama | in_memory
DEFAULT_VECTOR_STORE=postgres       # options: postgres | in_memory
DEFAULT_GRAPH_STORE=neo4j           # options: in_memory | neo4j
DEFAULT_ENTITY_EXTRACTOR=gemini     # options: gemini | ollama | in_memory

# ------------------------------------------------------------------
# PostgreSQL (pgvector) — RAG vector store
# ------------------------------------------------------------------
POSTGRES_DSN=postgresql+asyncpg://user:password@localhost:5432/graphrag

# ------------------------------------------------------------------
# Neo4j — GraphRAG graph store
# ------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=graphrag

# ------------------------------------------------------------------
# GraphRAG beam-search retriever
# ------------------------------------------------------------------
BEAM_SEARCH_MAX_ITERATIONS=20
BEAM_SEARCH_BEAM_WIDTH=8
TOG_DEPTH_MAX=3
