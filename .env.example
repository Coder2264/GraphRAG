# ------------------------------------------------------------------
# API Keys — fill in the ones you need
# ------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

# ------------------------------------------------------------------
# Ollama (local LLM + embeddings) — default provider
# ------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Embedding vector dimension — MUST match the model above:
#   nomic-embed-text  → 768
#   mxbai-embed-large → 1024
#   all-minilm        → 384
EMBEDDING_DIM=768

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ------------------------------------------------------------------
# Provider selection — swap instantly without code changes
# ------------------------------------------------------------------
DEFAULT_LLM=ollama          # options: ollama | in_memory | openai
DEFAULT_EMBEDDER=ollama     # options: ollama | in_memory | openai
DEFAULT_VECTOR_STORE=postgres  # options: postgres | in_memory
DEFAULT_GRAPH_STORE=in_memory  # options: in_memory | neo4j

# ------------------------------------------------------------------
# PostgreSQL (pgvector) — RAG vector store
# ------------------------------------------------------------------
POSTGRES_DSN=postgresql+asyncpg://user:password@localhost:5432/graphrag

# ------------------------------------------------------------------
# Neo4j — GraphRAG graph store (future)
# ------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

