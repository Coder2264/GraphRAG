# ------------------------------------------------------------------
# API Keys — fill in the ones you need
# ------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

# ------------------------------------------------------------------
# Gemini (entity extraction during ingestion)
# ------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_EXTRACTION_MODEL=gemini-2.5-pro

# ------------------------------------------------------------------
# Ollama (local LLM + embeddings) — default provider
# ------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EXTRACTION_TIMEOUT=600  # seconds for entity extraction; large docs need more than 2 min

# Embedding vector dimension — MUST match the model above:
#   nomic-embed-text  → 768
#   mxbai-embed-large → 1024
#   all-minilm        → 384
EMBEDDING_DIM=768

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ------------------------------------------------------------------
# Provider selection — swap instantly without code changes
# ------------------------------------------------------------------
DEFAULT_LLM=ollama                  # options: ollama | in_memory | openai
DEFAULT_EMBEDDER=ollama             # options: ollama | in_memory | openai
DEFAULT_VECTOR_STORE=postgres       # options: postgres | in_memory
DEFAULT_GRAPH_STORE=in_memory       # options: in_memory | neo4j
DEFAULT_ENTITY_EXTRACTOR=gemini     # options: gemini | ollama | in_memory

# ------------------------------------------------------------------
# PostgreSQL (pgvector) — RAG vector store
# ------------------------------------------------------------------
POSTGRES_DSN=postgresql+asyncpg://user:password@localhost:5432/graphrag

# ------------------------------------------------------------------
# Neo4j — GraphRAG graph store
# ------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=graphrag

# ------------------------------------------------------------------
# GraphRAG beam-search retriever
# ------------------------------------------------------------------
BEAM_SEARCH_MAX_ITERATIONS=20
BEAM_SEARCH_BEAM_WIDTH=8
TOG_DEPTH_MAX=3
